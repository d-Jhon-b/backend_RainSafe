{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["esnext"],
    "rootDir": "src",                   
    "outDir": "build",    
    
    "experimentalDecorators": true,         
    "emitDecoratorMetadata": true,          

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,                   
    
    "esModuleInterop": true,                
    "resolveJsonModule": true,              
    // "moduleResolution": "node",
    "isolatedModules": true,                
    
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],                  
  "exclude": ["node_modules", "build", "dist"] 
}